{
  "name": "poson-kiosk-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "POSON POS Self-Service Kiosk - Electron + Vue 3 + Node.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel dev:*",
    "dev:frontend": "pnpm --filter poson-kiosk dev",
    "dev:backend": "pnpm --filter poson-kiosk-backend dev",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:frontend": "pnpm --filter poson-kiosk build",
    "build:backend": "pnpm --filter poson-kiosk-backend build",
    "test": "pnpm run --parallel test:*",
    "test:frontend": "pnpm --filter poson-kiosk test",
    "test:backend": "pnpm --filter poson-kiosk-backend test",
    "lint": "pnpm run --parallel lint:*",
    "lint:frontend": "pnpm --filter poson-kiosk lint",
    "lint:backend": "pnpm --filter poson-kiosk-backend lint",
    "lint:fix": "pnpm run --parallel lint:fix:*",
    "lint:fix:frontend": "pnpm --filter poson-kiosk lint:fix",
    "lint:fix:backend": "pnpm --filter poson-kiosk-backend lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,jsx,json,css,md}\"",
    "typecheck": "pnpm run --parallel typecheck:*",
    "typecheck:frontend": "pnpm --filter poson-kiosk typecheck",
    "typecheck:backend": "pnpm --filter poson-kiosk-backend typecheck",
    "db:migrate": "pnpm --filter poson-kiosk-backend db:migrate",
    "db:generate": "pnpm --filter poson-kiosk-backend db:generate",
    "db:studio": "pnpm --filter poson-kiosk-backend db:studio",
    "clean": "pnpm run --parallel clean:*",
    "clean:frontend": "pnpm --filter poson-kiosk clean",
    "clean:backend": "pnpm --filter poson-kiosk-backend clean",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.11.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.3.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "playwright": "^1.58.1",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
