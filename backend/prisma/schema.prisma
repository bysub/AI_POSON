generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 카테고리
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  nameEn    String?   @map("name_en") @db.VarChar(100)
  nameJa    String?   @map("name_ja") @db.VarChar(100)
  nameZh    String?   @map("name_zh") @db.VarChar(100)
  imageUrl  String?   @map("image_url") @db.VarChar(500)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("categories")
}

// 상품 상태
enum ProductStatus {
  SELLING    // 판매중
  SOLD_OUT   // 품절
  PENDING    // 판매대기
  HIDDEN     // 숨김
}

// 과세 유형
enum TaxType {
  TAXABLE    // 과세
  TAX_FREE   // 면세
  ZERO_RATE  // 영세
}

// KIOSK 상품
model Product {
  id          Int             @id @default(autoincrement())
  barcode     String          @unique @db.VarChar(50)
  name        String          @db.VarChar(200)
  nameEn      String?         @map("name_en") @db.VarChar(200)
  nameJa      String?         @map("name_ja") @db.VarChar(200)
  nameZh      String?         @map("name_zh") @db.VarChar(200)
  description String?         @db.Text
  sellPrice   Decimal         @map("sell_price") @db.Decimal(18, 2)
  costPrice   Decimal?        @map("cost_price") @db.Decimal(18, 2)
  taxType     TaxType         @default(TAXABLE) @map("tax_type")
  status      ProductStatus   @default(SELLING)
  imageUrl    String?         @map("image_url") @db.VarChar(500)
  categoryId  Int             @map("category_id")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  category    Category        @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  options     ProductOption[]

  @@index([barcode])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

// 매입 상품 (다국어 불필요)
model PurchaseProduct {
  id         Int           @id @default(autoincrement())
  barcode    String        @unique @db.VarChar(50)
  name       String        @db.VarChar(200)
  sellPrice  Decimal       @map("sell_price") @db.Decimal(18, 2)
  costPrice  Decimal       @default(0) @map("cost_price") @db.Decimal(18, 2)
  spec         String?       @db.VarChar(100)
  productType  String?       @map("product_type") @db.VarChar(50)
  purchaseCost Decimal       @default(0) @map("purchase_cost") @db.Decimal(18, 2)
  vatAmount    Decimal       @default(0) @map("vat_amount") @db.Decimal(18, 2)
  taxType    TaxType       @default(TAXABLE) @map("tax_type")
  status     ProductStatus @default(SELLING)
  supplierId Int?          @map("supplier_id")
  lCode      String?       @map("l_code") @db.VarChar(2)
  mCode      String?       @map("m_code") @db.VarChar(2)
  sCode      String?       @map("s_code") @db.VarChar(3)
  isActive     Boolean       @default(true) @map("is_active")
  usePurchase  Boolean       @default(true) @map("use_purchase")
  useOrder     Boolean       @default(true) @map("use_order")
  useSales     Boolean       @default(true) @map("use_sales")
  useInventory Boolean       @default(true) @map("use_inventory")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  purchaseItems PurchaseItem[]

  @@index([barcode])
  @@index([supplierId])
  @@index([status])
  @@index([lCode, mCode, sCode])
  @@map("purchase_products")
}

// 상품 옵션
model ProductOption {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  name       String   @db.VarChar(100)
  price      Decimal  @db.Decimal(18, 2)
  isRequired Boolean  @default(false) @map("is_required")
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_options")
}

// 주문
model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique @map("order_number") @db.VarChar(20)
  kioskId     String?     @map("kiosk_id") @db.VarChar(50)
  totalAmount Decimal     @map("total_amount") @db.Decimal(18, 2)
  status      OrderStatus @default(PENDING)
  memo        String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")
  completedAt DateTime?   @map("completed_at")
  cancelledAt DateTime?   @map("cancelled_at")
  items       OrderItem[]
  payments    Payment[]

  @@index([orderNumber])
  @@index([createdAt])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  COMPLETED
  CANCELLED
}

// 주문 상품
model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   String   @map("order_id")
  productId Int      @map("product_id")
  name      String   @db.VarChar(200)
  price     Decimal  @db.Decimal(18, 2)
  quantity  Int
  options   Json?
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// 결제
model Payment {
  id             String        @id @default(uuid())
  orderId        String        @map("order_id")
  paymentType    PaymentType   @map("payment_type")
  amount         Decimal       @db.Decimal(18, 2)
  status         PaymentStatus @default(PENDING)
  vanCode        String?       @map("van_code") @db.VarChar(20)
  approvalNumber String?       @map("approval_number") @db.VarChar(50)
  transactionId  String?       @map("transaction_id") @db.VarChar(100)
  errorCode      String?       @map("error_code") @db.VarChar(20)
  errorMessage   String?       @map("error_message") @db.VarChar(500)
  createdAt      DateTime      @default(now()) @map("created_at")
  order          Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([transactionId])
  @@map("payments")
}

enum PaymentType {
  CARD
  CASH
  MIXED
}

enum PaymentStatus {
  PENDING
  APPROVED
  CANCELLED
  REFUNDED
  FAILED
}

// 회원
model Member {
  id        Int         @id @default(autoincrement())
  code      String      @unique @db.VarChar(20)
  name      String      @db.VarChar(100)
  phone     String      @db.VarChar(20)
  points    Int         @default(0)
  grade     MemberGrade @default(NORMAL)
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([phone])
  @@map("members")
}

enum MemberGrade {
  NORMAL
  SILVER
  GOLD
  VIP
}

// 관리자
model Admin {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(100)
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([username])
  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

// 키오스크 설정
model Kiosk {
  id           String   @id @default(uuid())
  kioskCode    String   @unique @map("kiosk_code") @db.VarChar(20)
  name         String   @db.VarChar(100)
  location     String?  @db.VarChar(200)
  vanProvider  String?  @map("van_provider") @db.VarChar(20)
  printerPort  String?  @map("printer_port") @db.VarChar(50)
  scannerPort  String?  @map("scanner_port") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  lastOnlineAt DateTime? @map("last_online_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("kiosks")
}

// 거래처 구분
enum SupplierType {
  FOOD        // 식품
  BEVERAGE    // 음료
  SUPPLIES    // 용품
  PACKAGING   // 포장재
  ETC         // 기타
}

// 거래처
model Supplier {
  id             Int          @id @default(autoincrement())
  code           String       @unique @db.VarChar(10)
  name           String       @db.VarChar(200)
  type           SupplierType @default(ETC)
  businessNumber String?      @unique @map("business_number") @db.VarChar(20)
  businessType   String?      @map("business_type") @db.VarChar(100)
  businessItem   String?      @map("business_item") @db.VarChar(100)
  representative String?      @db.VarChar(100)
  contactName    String?      @map("contact_name") @db.VarChar(100)
  contactPhone   String?      @map("contact_phone") @db.VarChar(20)
  contactEmail   String?      @map("contact_email") @db.VarChar(100)
  address        String?      @db.VarChar(300)
  addressDetail  String?      @map("address_detail") @db.VarChar(200)
  discountRate   Decimal      @default(0) @map("discount_rate") @db.Decimal(5, 2)
  paymentTerms   String?      @map("payment_terms") @db.VarChar(100)
  memo           String?      @db.Text
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  purchaseProducts PurchaseProduct[]
  purchases        Purchase[]

  @@index([name])
  @@index([type])
  @@index([isActive])
  @@map("suppliers")
}

// 매입 상태
enum PurchaseStatus {
  DRAFT      // 임시저장
  CONFIRMED  // 확정
  CANCELLED  // 취소
}

// 매입
model Purchase {
  id           Int            @id @default(autoincrement())
  purchaseCode String         @unique @map("purchase_code") @db.VarChar(20)
  supplierId   Int            @map("supplier_id")
  purchaseDate DateTime       @map("purchase_date") @db.Date
  totalAmount  Decimal        @default(0) @map("total_amount") @db.Decimal(18, 2)
  taxAmount    Decimal        @default(0) @map("tax_amount") @db.Decimal(18, 2)
  taxIncluded  Boolean        @default(true) @map("tax_included")
  status       PurchaseStatus @default(DRAFT)
  memo         String?        @db.Text
  createdBy    String?        @map("created_by") @db.VarChar(100)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]

  @@index([supplierId])
  @@index([purchaseDate])
  @@index([status])
  @@map("purchases")
}

// 매입 상세
model PurchaseItem {
  id                Int             @id @default(autoincrement())
  purchaseId        Int             @map("purchase_id")
  purchaseProductId Int             @map("purchase_product_id")
  quantity          Int
  unitPrice         Decimal         @map("unit_price") @db.Decimal(18, 2)
  sellPrice         Decimal         @default(0) @map("sell_price") @db.Decimal(18, 2)
  amount            Decimal         @db.Decimal(18, 2)
  createdAt         DateTime        @default(now()) @map("created_at")
  purchase          Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseProduct   PurchaseProduct @relation(fields: [purchaseProductId], references: [id])

  @@map("purchase_items")
}

// 대분류
model LBranch {
  lCode     String    @id @map("l_code") @db.VarChar(2)
  lName     String    @map("l_name") @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  mBranches MBranch[]
  @@map("l_branch")
}

// 중분류 (복합키: lCode + mCode)
model MBranch {
  lCode     String    @map("l_code") @db.VarChar(2)
  mCode     String    @map("m_code") @db.VarChar(2)
  mName     String    @map("m_name") @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  lBranch   LBranch   @relation(fields: [lCode], references: [lCode], onDelete: Restrict)
  sBranches SBranch[]
  @@id([lCode, mCode])
  @@map("m_branch")
}

// 소분류 (복합키: lCode + mCode + sCode)
model SBranch {
  lCode      String   @map("l_code") @db.VarChar(2)
  mCode      String   @map("m_code") @db.VarChar(2)
  sCode      String   @map("s_code") @db.VarChar(3)
  sName      String   @map("s_name") @db.VarChar(100)
  profitRate Decimal  @default(0) @map("profit_rate") @db.Decimal(5, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  mBranch    MBranch  @relation(fields: [lCode, mCode], references: [lCode, mCode], onDelete: Restrict)
  @@id([lCode, mCode, sCode])
  @@map("s_branch")
}

// 시스템 설정
model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  category  String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_settings")
}
